+# Pyodide shim: bridge onnxruntime-web via the JavaScript FFI.
+# This runs when the native C extension cannot be loaded, which is the case
+# in Pyodide (Emscripten/WebAssembly). The onnxruntime-web JavaScript
+# library is loaded from a CDN to provide the InferenceSession API.
+import js as _js  # noqa: PLC0415
+import numpy as _np  # noqa: PLC0415
+from pyodide.ffi import run_sync as _run_sync, to_js as _to_js  # noqa: PLC0415
+
+_ORT_VERSION = "1.24.2"
+_ORT_CDN_BASE = f"https://cdn.jsdelivr.net/npm/onnxruntime-web@{_ORT_VERSION}/dist"
+
+# Load onnxruntime-web from CDN.
+# importScripts() is synchronous and available in Web Workers (the typical
+# Pyodide deployment context, e.g. JupyterLite).
+if hasattr(_js, "importScripts"):
+    _js.importScripts(f"{_ORT_CDN_BASE}/ort.min.js")
+else:
+    raise ImportError(
+        "onnxruntime requires a web worker context (importScripts) when "
+        "running in Pyodide. Ensure you are running in JupyterLite or a "
+        "similar web worker environment."
+    )
+
+_js.ort.env.wasm.wasmPaths = f"{_ORT_CDN_BASE}/"
+
+_NUMPY_DTYPE_TO_ORT_TYPE = {
+    "float16": "float16",
+    "float32": "float32",
+    "float64": "double",
+    "int8": "int8",
+    "int16": "int16",
+    "int32": "int32",
+    "int64": "int64",
+    "uint8": "uint8",
+    "uint16": "uint16",
+    "uint32": "uint32",
+    "uint64": "uint64",
+    "bool": "bool",
+}
+
+def _numpy_to_ort_tensor(array):
+    array = _np.ascontiguousarray(array)
+    ort_type = _NUMPY_DTYPE_TO_ORT_TYPE.get(array.dtype.name)
+    if ort_type is None:
+        raise TypeError(f"Unsupported numpy dtype for onnxruntime: {array.dtype}")
+    # to_js converts a numpy array to the corresponding JS TypedArray
+    # (e.g. float32 -> Float32Array, int32 -> Int32Array).
+    flat = _to_js(array.ravel(), create_pyproxies=False)
+    dims = _to_js(list(array.shape))
+    return _js.ort.Tensor.new(ort_type, flat, dims)
+
+def _ort_tensor_to_numpy(tensor):
+    data = _np.array(tensor.data.to_py())
+    dims = [int(d) for d in tensor.dims.to_py()]
+    return data.reshape(dims)
+
+class NodeArg:
+    """Represents model input/output metadata (name, type, shape)."""
+
+    def __init__(self, name, type_, shape):
+        self._name = name
+        self._type = type_
+        self._shape = shape
+
+    @property
+    def name(self):
+        return self._name
+
+    @property
+    def type(self):
+        return self._type
+
+    @property
+    def shape(self):
+        return self._shape
+
+    def __repr__(self):
+        return f"NodeArg(name={self._name!r}, type={self._type!r}, shape={self._shape})"
+
+class InferenceSession:
+    """ONNX Runtime InferenceSession backed by onnxruntime-web via Pyodide."""
+
+    def __init__(
+        self,
+        path_or_bytes,
+        sess_options=None,
+        providers=None,
+        provider_options=None,
+        **kwargs,
+    ):
+        import os as _os  # noqa: PLC0415
+
+        if isinstance(path_or_bytes, (str, _os.PathLike)):
+            model_input = str(path_or_bytes)
+        elif isinstance(path_or_bytes, bytes):
+            model_input = _to_js(path_or_bytes, create_pyproxies=False)
+        else:
+            raise TypeError(f"Unsupported model input type: {type(path_or_bytes)}")
+
+        self._session = _run_sync(_js.ort.InferenceSession.create(model_input))
+
+    def run(self, output_names, input_feed, run_options=None):
+        js_feeds = _js.Object.new()
+        for name, value in input_feed.items():
+            setattr(js_feeds, name, _numpy_to_ort_tensor(_np.asarray(value)))
+
+        if output_names is not None:
+            js_fetches = _js.Object.new()
+            for name in output_names:
+                setattr(js_fetches, name, None)
+            js_results = _run_sync(self._session.run(js_feeds, js_fetches))
+        else:
+            js_results = _run_sync(self._session.run(js_feeds))
+            output_names = [str(n) for n in self._session.outputNames]
+
+        return [_ort_tensor_to_numpy(js_results[name]) for name in output_names]
+
+    def get_inputs(self):
+        return [NodeArg(str(n), None, None) for n in self._session.inputNames]
+
+    def get_outputs(self):
+        return [NodeArg(str(n), None, None) for n in self._session.outputNames]
+
+    def get_providers(self):
+        return ["WebAssemblyExecutionProvider"]
+
+    def get_session_options(self):
+        return None
+
+
